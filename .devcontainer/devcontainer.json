{
  "name": "agent-dev-desktop",
  "build": { "dockerfile": "Dockerfile" },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/python:1": { "version": "3.12" },
    "ghcr.io/devcontainers/features/sshd:1": {},
    // gh CLI: the setup wizard's pick-repo step uses it (gh repo list / secret
    // set / repo clone), and Central drives the desktop over `gh codespace ssh`.
    "ghcr.io/devcontainers/features/github-cli:1": {},
    // Docker-in-Docker: agents run lots of cloned apps here, many of which ship a
    // docker-compose (esp. DB-backed ones) — run them in containers instead of
    // installing services onto the codespace. Keeps apps isolated and the base
    // image clean.
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  // Headroom for container images now that apps run under Docker (default is
  // ~32GB, which fills quickly across many app images).
  "hostRequirements": { "storage": "64gb" },
  // 6080 must be in forwardPorts so the public forwarded URL
  // (<codespace>-6080.app.github.dev) actually maps to it. Auto-forward only
  // fires when the VS Code editor client detects the listener; the Codespaces
  // Manager app starts the desktop headlessly over `gh codespace ssh` with no
  // editor attached, so without this the port is never forwarded and the URL
  // 404s. The downside — the forwarder transiently pre-binds 6080 at boot, so a
  // desktop launched right then dies with EADDRINUSE — is handled by
  // start-desktop.sh, which retries until the pre-bind releases and KasmVNC
  // binds (post-boot 6080 is reliably free).
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": { "label": "desktop (KasmVNC)", "onAutoForward": "openPreview" }
  },
  "containerEnv": {
    "DISPLAY": ":1",
    "BROWSER": "/usr/local/bin/google-chrome"
  },
  // Install the agent CLI, make the projects dir, and pre-install the setup
  // wizard's deps so the folderOpen autostart task launches instantly (no npm
  // install on first open). Runs in the workspace folder (/workspaces/<repo>).
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code && mkdir -p $HOME/projects && npm --prefix setup-wizard install",
  // Start the Axon bridge under supervisord on every codespace start. supervisord
  // daemonizes and keeps it alive (restart/backoff/logging). On the very first
  // boot the bridge has no .env yet — it waits, re-reading .env every few seconds
  // until Central's provisioning writes the keys (see wait_for_config in
  // axon_bridge.py). The /workspaces volume persists across stop/start, so on
  // later starts the .env is already there and the bridge comes up immediately.
  "postStartCommand": "supervisord -c claude-slack-bot/supervisord.conf || true",
  // The desktop is intentionally NOT started here. A KasmVNC launched from a
  // lifecycle command (postStart/postCreate) is reaped by Codespaces shortly
  // after the command finishes, so it's reliably down by the time anyone
  // connects. The Codespaces Manager app starts it on demand by running
  // /usr/local/bin/start-desktop.sh over `gh codespace ssh` (an exec context
  // that survives), which is where the desktop actually stays up.
  "remoteUser": "vscode"
}
