{
  "name": "agent-dev-desktop",
  "build": { "dockerfile": "Dockerfile" },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/python:1": { "version": "3.12" },
    "ghcr.io/devcontainers/features/sshd:1": {}
  },
  // Deliberately NOT in forwardPorts: eagerly forwarding 6080 makes the
  // Codespaces port forwarder pre-bind the port at boot, so KasmVNC then dies
  // with EADDRINUSE and the desktop never comes up. Let KasmVNC bind first;
  // Codespaces auto-forwards 6080 once it sees the listener. portsAttributes
  // still applies to the auto-forwarded port.
  "portsAttributes": {
    "6080": { "label": "desktop (KasmVNC)", "onAutoForward": "openPreview" }
  },
  "containerEnv": {
    "DISPLAY": ":1",
    "BROWSER": "/usr/local/bin/google-chrome"
  },
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code && mkdir -p $HOME/projects",
  "postStartCommand": "bash /usr/local/bin/start-desktop.sh",
  "remoteUser": "vscode"
}
