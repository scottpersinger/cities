# --- Slack (acts as a real user, not a bot) ---
# The app authenticates as a real Slack user via OAuth and acts as that user.
#
# One-time setup to mint the user token:
#   1. api.slack.com/apps -> your app -> "Basic Information": copy Client ID /
#      Client Secret into the two vars below.
#   2. "OAuth & Permissions" -> "Redirect URLs": add the redirect below, Save.
#   3. Run `uv run python slack_auth.py`, approve in the browser. It writes the
#      user token to `.slack_user_token` and prints SLACK_USER_TOKEN for here.
SLACK_CLIENT_ID=replace-me
SLACK_CLIENT_SECRET=replace-me

# Must exactly match a Redirect URL registered on the Slack app.
# SLACK_OAUTH_REDIRECT_URI=http://localhost:4555/oauth/callback

# User token (xoxp-...). Minted by slack_auth.py. If unset, app.py falls back
# to reading the `.slack_user_token` file written by that script.
# SLACK_USER_TOKEN=xoxp-replace-me

# How often to poll Slack for new messages, in seconds. Default: 10.
# conversations.history runs once per DM per cycle and is rate-limited
# (~50 req/min), so keep interval_s >= active_DMs * 60 / 50. Raise it if you
# see "ratelimited" warnings in the logs.
# SLACK_POLL_INTERVAL_S=10

# Set to 1 to also respond to @-mentions of you in channels (via search.messages
# — needs the search:read scope and lags a few seconds). DMs are always watched.
# SLACK_WATCH_MENTIONS=1

# --- Claude ---
# Working directory the persistent claude process runs in.
CLAUDE_CWD=/Users/scottp

# One of: default | acceptEdits | plan | bypassPermissions
# bypassPermissions = no approval prompts (you won't see them in Slack anyway).
CLAUDE_PERMISSION_MODE=bypassPermissions

# Optional: pin the model. Leave blank to use claude's default.
# CLAUDE_MODEL=claude-opus-4-7

# Which setting sources the spawned `claude` should inherit from.
# Comma-separated subset of: user,project,local
# Default loads all three so MCP servers, slash commands, agents, and skills
# from your normal Claude Code config are available. Set to empty to isolate.
CLAUDE_SETTING_SOURCES=user,project,local

# Set to 1 to start each `claude` subprocess with --chrome, which enables
# the Claude-in-Chrome browser MCP. Requires the Chrome extension installed
# and onboarded for this user.
# CLAUDE_CHROME=1

# Optional sidecar progress channel — one message per turn, edited in place
# with a header (link back to source thread + user), one line per tool call,
# and a final ✅/❌ result line. Channel ID (e.g. C0123ABCD), not "#botspeak".
# You (the signed-in user) must be a member of the channel.
# BOTSPEAK_CHANNEL=C0123ABCD

# Close (and free the ~80–130 MB `claude` subprocess for) any session that
# has been idle for this many seconds. Threads still work — the next reply
# in an evicted thread just spawns a fresh subprocess. Default: 14400 (4h).
# Set to 0 to disable eviction entirely.
# SESSION_IDLE_TIMEOUT_S=14400

# How often the reaper scans for idle sessions, in seconds. Default: 300 (5m).
# SESSION_REAP_INTERVAL_S=300

# --- GitHub PR review poller ---
# When a PR has PR_REVIEW_LOGIN assigned as a requested reviewer, Bizzybot
# announces it in this channel and starts a thread asking the agent to
# review it. Unset to disable the poller. You (the signed-in user) must be a
# member of the channel. Uses the host `gh` CLI for auth (gh auth login).
# PR_REVIEW_CHANNEL=C0123ABCD
# PR_REVIEW_LOGIN=bizzy-btbot
# PR_POLL_INTERVAL_S=60

# --- Misc ---
LOG_LEVEL=INFO
