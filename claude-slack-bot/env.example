# --- Slack ---
# The easiest way to populate the Slack vars is `install.py` (App Manifest +
# OAuth v2). See the README. In short:
#   1. python install.py manifest --name <bot-name>   # create the app
#   2. copy the app's Client ID / Client Secret below
#   3. python install.py install                       # writes SLACK_BOT_TOKEN
#   4. add the app-level token below (still a manual UI step)

# Bot token (xoxb-...). Written automatically by `python install.py install`,
# or copy it from "OAuth & Permissions" -> "Bot User OAuth Token".
SLACK_BOT_TOKEN=xoxb-replace-me

# App-level token (xapp-...), scope `connections:write`. Required for Socket
# Mode. Slack has no API for this one — create it under "Basic Information" ->
# "App-Level Tokens" and paste it here.
SLACK_APP_TOKEN=xapp-replace-me

# OAuth v2 install credentials (used by `python install.py install`). Copy from
# the app's "Basic Information" page after creating it.
SLACK_CLIENT_ID=replace-me
SLACK_CLIENT_SECRET=replace-me

# Redirect URI for the OAuth install flow. Must match the manifest's
# redirect_urls (install.py registers this value at create time). Override only
# if localhost:4555 is taken.
# SLACK_OAUTH_REDIRECT_URI=http://localhost:4555/oauth/callback

# --- Claude ---
# The claude subprocess runs in the directory the bot is launched from (its
# CWD) — there's no CLAUDE_CWD anymore. `cd` to the project you want the agent
# to work in, then start the bot.

# One of: default | acceptEdits | plan | bypassPermissions
# bypassPermissions = no approval prompts (you won't see them in Slack anyway).
CLAUDE_PERMISSION_MODE=bypassPermissions

# Optional: pin the model. Leave blank to use claude's default.
# CLAUDE_MODEL=claude-opus-4-7

# Which setting sources the spawned `claude` should inherit from.
# Comma-separated subset of: user,project,local
# Default loads all three so MCP servers, slash commands, agents, and skills
# from your normal Claude Code config are available. Set to empty to isolate.
CLAUDE_SETTING_SOURCES=user,project,local

# Whether each `claude` subprocess starts with --chrome, enabling the
# Claude-in-Chrome browser MCP. Defaults to ON (requires the Chrome extension
# installed and onboarded for this user). Set to 0 to disable.
# CLAUDE_CHROME=0

# Optional sidecar progress channel — one message per turn, edited in place
# with a header (link back to source thread + user), one line per tool call,
# and a final ✅/❌ result line. Channel ID (e.g. C0123ABCD), not "#botspeak".
# Invite the bot to the channel before setting this.
# BOTSPEAK_CHANNEL=C0123ABCD

# --- Axon bridge (axon_bridge.py: Central -> codespace event bus) ---
# See central/docs/axon-event-bus.md and docs/axon-multitenant-security.md.
# These are normally delivered as Codespaces secrets so they're present in the
# codespace automatically.
#
# The bridge has two transports (pick via env):
#
#   * Relay mode (multi-tenant safe) — set AXON_RELAY_URL + AXON_RELAY_TOKEN
#     below. Central holds the Runloop key and proxies ONLY this codespace's
#     Axon, so no Runloop credential lives in the codespace. Use this for
#     multi-tenant. RUNLOOP_API_KEY/AXON_ID are not needed.
#
#   * Direct mode (legacy, default) — the codespace holds RUNLOOP_API_KEY and
#     talks to Runloop directly. Runloop has NO per-axon authorization, so that
#     key can read/publish EVERY tenant's Axon. Only use single-tenant.

# -- Relay mode (preferred for multi-tenant) --
# Central's per-codespace SSE relay base; the bridge GETs {AXON_RELAY_URL}/subscribe/sse.
# AXON_RELAY_URL=https://central.example.com/axon-relay
# Per-codespace bearer token Central issues; it maps to exactly this codespace's
# Axon. Treat as a secret. Required when AXON_RELAY_URL is set.
# AXON_RELAY_TOKEN=replace-me

# -- Direct mode (legacy / single-tenant) --
# Runloop API key — the bridge's credential for the Axon SSE stream and for
# resolving its Axon by name. Account-scoped: reaches every Axon in the account,
# so do NOT use this for multi-tenant (see docs/axon-multitenant-security.md).
RUNLOOP_API_KEY=ak-replace-me

# How the bridge finds its Axon in direct mode: prefer injecting AXON_ID (Central
# names each codespace's Axon `cs-<CODESPACE_NAME>`), which avoids the
# account-wide `GET /v1/axons` listing. Without AXON_ID it falls back to that
# listing (logs a SECURITY warning). CODESPACE_NAME is always set in a codespace.
# AXON_ID=axn_...

# Direct mode only: set to 0 to forbid the account-wide name-lookup fallback and
# require AXON_ID to be provisioned. Recommended in multi-tenant setups that
# still use direct mode.
# AXON_ALLOW_NAME_LOOKUP=1

# Override the Runloop API base (rarely needed).
# RUNLOOP_BASE_URL=https://api.runloop.ai

# --- Misc ---
LOG_LEVEL=INFO
