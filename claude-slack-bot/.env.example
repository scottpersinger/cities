# --- Slack ---
# Bot token: from "OAuth & Permissions" -> "Bot User OAuth Token" (xoxb-...)
SLACK_BOT_TOKEN=xoxb-replace-me

# App-level token: from "Basic Information" -> "App-Level Tokens", scope `connections:write` (xapp-...)
# Required for Socket Mode.
SLACK_APP_TOKEN=xapp-replace-me

# --- Claude ---
# Working directory the persistent claude process runs in.
CLAUDE_CWD=/Users/scottp

# One of: default | acceptEdits | plan | bypassPermissions
# bypassPermissions = no approval prompts (you won't see them in Slack anyway).
CLAUDE_PERMISSION_MODE=bypassPermissions

# Optional: pin the model. Leave blank to use claude's default.
# CLAUDE_MODEL=claude-opus-4-7

# Which setting sources the spawned `claude` should inherit from.
# Comma-separated subset of: user,project,local
# Default loads all three so MCP servers, slash commands, agents, and skills
# from your normal Claude Code config are available. Set to empty to isolate.
CLAUDE_SETTING_SOURCES=user,project,local

# Set to 1 to start each `claude` subprocess with --chrome, which enables
# the Claude-in-Chrome browser MCP. Requires the Chrome extension installed
# and onboarded for this user.
# CLAUDE_CHROME=1

# Optional sidecar progress channel — one message per turn, edited in place
# with a header (link back to source thread + user), one line per tool call,
# and a final ✅/❌ result line. Channel ID (e.g. C0123ABCD), not "#botspeak".
# Invite the bot to the channel before setting this.
# BOTSPEAK_CHANNEL=C0123ABCD

# --- Misc ---
LOG_LEVEL=INFO
